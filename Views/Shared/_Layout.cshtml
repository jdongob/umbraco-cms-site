@using Umbraco.Cms.Core.Models.PublishedContent
@using Umbraco.Extensions

@inject Umbraco.Cms.Web.Common.UmbracoHelper Umbraco

@{
    var home = Umbraco.ContentAtRoot().FirstOrDefault();
    var current = Model;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>My Umbraco Project</title>

    <link rel="stylesheet" href="/css/site.css" />
</head>

<body>

    <header class="header">

        <h2 class="logo">My Umbraco Demo</h2>


        <nav class="nav">

            @if (home != null)
            {
                <a href="@home.Url()" class="nav-link @(current.Id == home.Id ? "active" : "")">
                    Home
                </a>

                @foreach (var item in home.Children())
                {
                    if (item.IsVisible())
                    {
                        <a href="@item.Url()" class="nav-link @(current.Id == item.Id ? "active" : "")">
                            @item.Name
                        </a>
                    }
                }
            }

        </nav>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer style="text-align:center; padding:20px; font-size:12px; color:#999;">
        Built with Umbraco + ASP.NET Core
    </footer>

</body>
</html>